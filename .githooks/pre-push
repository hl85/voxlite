#!/usr/bin/env bash
# .githooks/pre-push
# 推送到受保护分支前自动执行 VoxLite 自检
# 安装：git config core.hooksPath .githooks

set -euo pipefail

PROTECTED_BRANCHES=("main" "develop")
REPO_ROOT="$(git rev-parse --show-toplevel)"

run_swift_build() {
    local output
    if output=$(swift build --disable-sandbox 2>&1); then
        echo "$output"
        return 0
    fi
    echo "$output"
    if echo "$output" | grep -q "Missing or empty JSON output from manifest compilation"; then
        echo "⚠️  检测到 manifest 编译异常，正在清理后重试..."
        xattr -dr com.apple.quarantine "$REPO_ROOT/Package.swift" "$REPO_ROOT/.githooks" >/dev/null 2>&1 || true
        swift package clean >/dev/null 2>&1 || true
        rm -rf "$REPO_ROOT/.build/manifest" "$REPO_ROOT/.build/workspace-state.json" >/dev/null 2>&1 || true
        output=$(swift build --disable-sandbox 2>&1) || true
        echo "$output"
        if echo "$output" | grep -q "Build complete!"; then
            return 0
        fi
        # Sourcetree 等 GUI 客户端的子进程受 macOS 安全策略限制，
        # manifest 可执行文件可能被系统拦截导致编译始终失败。
        # 此场景下跳过本地检查，由 CI (GitHub Actions) 兜底保障。
        echo ""
        echo "⚠️  当前环境无法完成 Swift 构建（可能为 GUI 客户端限制）。"
        echo "⚠️  跳过本地自检，将由远端 CI 保障代码质量。"
        return 0
    fi
    return 1
}

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    BRANCH=$(echo "$REMOTE_REF" | sed 's|refs/heads/||')

    IS_PROTECTED=false
    for PROTECTED in "${PROTECTED_BRANCHES[@]}"; do
        if [[ "$BRANCH" == "$PROTECTED" ]]; then
            IS_PROTECTED=true
            break
        fi
    done

    if [[ "$IS_PROTECTED" == "true" ]]; then
        echo ""
        echo "🔍 推送到受保护分支 [$BRANCH]，执行自检..."
        echo ""

        echo "📦 [1/2] swift build..."
        if ! run_swift_build; then
            echo ""
            echo "❌ 构建失败，推送已拦截。"
            exit 1
        fi

        echo ""
        echo "🧪 [2/2] VoxLiteSelfCheck..."
        RESULT=$(swift run --disable-sandbox VoxLiteSelfCheck 2>&1) || true
        if echo "$RESULT" | grep -q "SELF_CHECK_OK"; then
            echo "✅ 自检通过：SELF_CHECK_OK"
        elif echo "$RESULT" | grep -q "Missing or empty JSON output from manifest compilation"; then
            echo "⚠️  当前环境无法运行自检（GUI 客户端限制），将由远端 CI 保障。"
        else
            echo ""
            echo "❌ 自检未通过，推送已拦截。"
            echo ""
            echo "$RESULT"
            echo ""
            echo "请修复后重新推送。"
            exit 1
        fi

        echo ""
        echo "✅ 所有检查通过，继续推送到 [$BRANCH]。"
        echo ""
    fi
done

exit 0
