#!/usr/bin/env bash
# .githooks/pre-push
# 推送到受保护分支前自动执行 VoxLite 自检
# 安装：git config core.hooksPath .githooks

set -euo pipefail

PROTECTED_BRANCHES=("main" "develop")
REPO_ROOT="$(git rev-parse --show-toplevel)"

is_gui_git_client() {
    [[ -n "${SOURCETREE:-}" ]] || [[ -n "${SOURCE_TREE:-}" ]]
}

block_protected_branch_gui_push() {
    local branch="$1"
    echo ""
    echo "❌ 已拦截通过 GUI Git 客户端向受保护分支 [$branch] 的推送。"
    echo ""
    echo "原因：SourceTree 等 GUI 客户端触发的 Git Hook 运行在与终端不同的 macOS 安全上下文中，"
    echo "SwiftPM manifest 编译与 VoxLiteSelfCheck 可能被系统限制，无法作为稳定可信的本地门禁。"
    echo ""
    echo "请改用终端推送到受保护分支，例如："
    echo "  git push voxlite HEAD:refs/heads/$branch"
    echo ""
    echo "如需使用 SourceTree，请先推送到非受保护分支，再通过 PR 合入。"
}

run_swift_build() {
    local output
    if output=$(swift build --disable-sandbox 2>&1); then
        echo "$output"
        return 0
    fi
    echo "$output"
    if echo "$output" | grep -q "Missing or empty JSON output from manifest compilation"; then
        echo "⚠️  检测到 manifest 编译异常，正在清理后重试..."
        xattr -dr com.apple.quarantine "$REPO_ROOT/Package.swift" "$REPO_ROOT/.githooks" >/dev/null 2>&1 || true
        swift package clean >/dev/null 2>&1 || true
        rm -rf "$REPO_ROOT/.build/manifest" "$REPO_ROOT/.build/workspace-state.json" >/dev/null 2>&1 || true
        output=$(swift build --disable-sandbox 2>&1) || true
        echo "$output"
        if echo "$output" | grep -q "Build complete!"; then
            return 0
        fi
        return 2
    fi
    return 1
}

while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
    BRANCH=$(echo "$REMOTE_REF" | sed 's|refs/heads/||')

    IS_PROTECTED=false
    for PROTECTED in "${PROTECTED_BRANCHES[@]}"; do
        if [[ "$BRANCH" == "$PROTECTED" ]]; then
            IS_PROTECTED=true
            break
        fi
    done

    if [[ "$IS_PROTECTED" == "true" ]]; then
        if is_gui_git_client; then
            block_protected_branch_gui_push "$BRANCH"
            exit 1
        fi

        echo ""
        echo "🔍 推送到受保护分支 [$BRANCH]，执行自检..."
        echo ""

        echo "📦 [1/2] swift build..."
        run_swift_build
        BUILD_EXIT_CODE=$?
        if [[ "$BUILD_EXIT_CODE" -ne 0 ]]; then
            echo ""
            if [[ "$BUILD_EXIT_CODE" -eq 2 ]]; then
                block_protected_branch_gui_push "$BRANCH"
                exit 1
            fi
            echo "❌ 构建失败，推送已拦截。"
            exit 1
        fi

        echo ""
        echo "🧪 [2/2] VoxLiteSelfCheck..."
        RESULT=$(swift run --disable-sandbox VoxLiteSelfCheck 2>&1) || true
        if echo "$RESULT" | grep -q "SELF_CHECK_OK"; then
            echo "✅ 自检通过：SELF_CHECK_OK"
        elif echo "$RESULT" | grep -q "Missing or empty JSON output from manifest compilation"; then
            block_protected_branch_gui_push "$BRANCH"
            exit 1
        else
            echo ""
            echo "❌ 自检未通过，推送已拦截。"
            echo ""
            echo "$RESULT"
            echo ""
            echo "请修复后重新推送。"
            exit 1
        fi

        echo ""
        echo "✅ 所有检查通过，继续推送到 [$BRANCH]。"
        echo ""
    fi
done

exit 0
