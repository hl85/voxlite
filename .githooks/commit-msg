#!/usr/bin/env bash
# .githooks/commit-msg
# 校验 Conventional Commits 格式
# 安装：git config core.hooksPath .githooks

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# 跳过 Merge commit 和 Revert commit
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert) "; then
    exit 0
fi

PATTERN="^(feat|fix|test|refactor|perf|chore|docs|ci)(\([a-z0-9_/-]+\))?: .{1,100}$"

if ! echo "$COMMIT_MSG" | head -1 | grep -qE "$PATTERN"; then
    echo ""
    echo "❌ Commit message 格式不符合规范。"
    echo ""
    echo "   期望格式：<type>(<scope>): <描述>"
    echo "   合法类型：feat | fix | test | refactor | perf | chore | docs | ci"
    echo ""
    echo "   示例："
    echo "     feat(input): support custom hotkey configuration"
    echo "     fix(output): restore clipboard after injection failure"
    echo "     test(pipeline): add regression for timeout retry"
    echo ""
    echo "   你的提交信息：$COMMIT_MSG"
    echo ""
    exit 1
fi

exit 0
